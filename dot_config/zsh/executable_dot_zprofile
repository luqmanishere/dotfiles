# Are we in the bottle?
if [[ ! -v INSIDE_GENIE ]]; then
  read -p "yn? * Not inside the genie bottle; enter it? " yn
  echo

  if [[ $yn == "y" ]]; then
    echo "Starting genie:"
    exec /usr/bin/genie -s
  fi
fi

if [[ -v SSH_CLIENT ]]; then
  source <(systemctl show-environment | awk '{print "export "$0}')
fi
